      { "type": "RATE", "rate": 16000, "durationMillis": 30000, "maxVus": 4000 },
      { "type": "RATE", "rate": 32000, "durationMillis": 30000, "maxVus": 4000 },
      { "type": "RATE", "rate": 64000, "durationMillis": 30000, "maxVus": 4000 }
