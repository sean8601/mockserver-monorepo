{
  "name": "mockserver",
  "displayName": "MockServer",
  "description": "Start, stop, and manage MockServer Docker containers directly from VS Code",
  "version": "7.1.0",
  "publisher": "mockserver",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mock-server/mockserver.git",
    "directory": "mockserver-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "mockserver",
    "mock",
    "http",
    "api",
    "testing",
    "docker"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mockserver.start",
        "title": "MockServer: Start (Docker)"
      },
      {
        "command": "mockserver.stop",
        "title": "MockServer: Stop"
      },
      {
        "command": "mockserver.openDashboard",
        "title": "MockServer: Open Dashboard"
      },
      {
        "command": "mockserver.openDashboardInEditor",
        "title": "MockServer: Open Dashboard (in editor)"
      },
      {
        "command": "mockserver.loadExpectations",
        "title": "MockServer: Load Expectations Into Running Server"
      },
      {
        "command": "mockserver.diffAgainstLive",
        "title": "MockServer: Diff Expectations Against Live Server"
      },
      {
        "command": "mockserver.saveRecorded",
        "title": "MockServer: Save Recorded Expectations (JSON or Java)"
      },
      {
        "command": "mockserver.generateFromOpenApi",
        "title": "MockServer: Generate Expectations From OpenAPI Spec"
      },
      {
        "command": "mockserver.sendRequest",
        "title": "MockServer: Send Test Request"
      },
      {
        "command": "mockserver.showDrift",
        "title": "MockServer: Show Drift Report"
      },
      {
        "command": "mockserver.showDriftDiagnostics",
        "title": "MockServer: Show Drift as Diagnostics"
      },
      {
        "command": "mockserver.viewRequestLog",
        "title": "MockServer: View Request Log"
      },
      {
        "command": "mockserver.reset",
        "title": "MockServer: Reset (Clear Expectations & Logs)"
      }
    ],
    "snippets": [
      {
        "language": "json",
        "path": "./snippets/expectation.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "*.mockserver.json",
          "*.mockserver.jsonc"
        ],
        "url": "./schemas/mockserver-expectation.schema.json"
      }
    ],
    "configuration": {
      "title": "MockServer",
      "properties": {
        "mockserver.dockerImage": {
          "type": "string",
          "default": "",
          "markdownDescription": "Docker image used to start MockServer. Leave empty to use `mockserver/mockserver:<extension-version>`, which keeps the image tag in lockstep with this extension."
        },
        "mockserver.containerName": {
          "type": "string",
          "default": "mockserver-vscode",
          "description": "Name of the MockServer Docker container started and stopped by this extension."
        },
        "mockserver.port": {
          "type": "number",
          "default": 1080,
          "description": "Host port mapped to the MockServer container's port 1080 (used for the dashboard URL and the run command)."
        }
      }
    }
  },
  "scripts": {
    "generate-schema": "node ../scripts/generate-editor-expectation-schema.mjs",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/extension.test.js",
    "vscode:prepublish": "npm run generate-schema && npm run compile",
    "package": "vsce package",
    "publish:marketplace": "vsce publish -p $VSCE_PAT",
    "publish:openvsx": "ovsx publish -p $OVSX_PAT"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  }
}
