{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(scripts/ci/bk-pipeline-status.sh:*)",
      "Bash(./scripts/ci/bk-pipeline-status.sh:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"Claude Code — MockServer\"'"
          },
          {
            "type": "command",
            "command": "bash .opencode/scripts/aggregate-telemetry.sh .tmp/decisions --csv .tmp/telemetry-latest.csv >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
