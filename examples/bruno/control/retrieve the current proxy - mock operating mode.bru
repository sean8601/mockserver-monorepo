meta {
  name: retrieve the current proxy / mock operating mode
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/mockserver/mode
  body: none
  auth: none
}

docs {
  returns the current operating mode and whether unmatched requests are proxied
  
