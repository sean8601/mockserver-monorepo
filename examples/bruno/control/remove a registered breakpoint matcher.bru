meta {
  name: remove a registered breakpoint matcher
  type: http
  seq: 20
}

put {
  url: {{baseUrl}}/mockserver/breakpoint/matcher/remove
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "id": "78fa44ff-5989-467a-ba44-ff5989667a71"
  }
}

docs {
  Removes a previously registered breakpoint matcher by id. Returns status "removed" on success or 404 if no matcher with the given id exists.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
