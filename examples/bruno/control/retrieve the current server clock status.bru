meta {
  name: retrieve the current server clock status
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/mockserver/clock
  body: none
  auth: none
}

docs {
  Returns the current instant, epoch milliseconds, and whether the clock is frozen.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
