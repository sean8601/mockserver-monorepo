  url: {{baseUrl}}/mockserver/retrieve
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

params:query {
  ~format: java
  ~type: logs
}

body:json {
  {
    "path": "/api/users"
  }
}

docs {
  Retrieve recorded requests, active expectations, recorded expectations or log messages.
  
  request used to match which recorded requests, expectations or log messages to return, an empty body matches all requests, expectations or log messages
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
