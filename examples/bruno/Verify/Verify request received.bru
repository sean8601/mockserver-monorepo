meta {
  name: Verify request received
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/mockserver/verify
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "httpRequest": { "path": "/hello" },
    "times": { "atLeast": 1 }
  }
}

docs {
  202 if the request was received the expected number of times; 406 with a failure message otherwise.
}
