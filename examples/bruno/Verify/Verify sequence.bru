meta {
  name: Verify sequence
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/mockserver/verifySequence
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "httpRequests": [
      { "path": "/hello" }
    ]
  }
}

docs {
  Verify a set of requests were received in the given order.
}
