meta {
  name: externally trigger a scenario state transition
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/mockserver/scenario/checkout/trigger
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "newState": "Failed"
  }
}

docs {
  Advances the named scenario to newState immediately. Intended for driving a scenario forward from a test harness or CI pipeline.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
