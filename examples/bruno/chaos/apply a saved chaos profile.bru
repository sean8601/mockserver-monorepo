meta {
  name: apply a saved chaos profile
  type: http
  seq: 20
}

post {
  url: {{baseUrl}}/mockserver/chaosExperiment/apply/checkout
  body: none
  auth: inherit
}

docs {
  Starts the chaos experiment previously saved under the given name (as if its definition had been sent to PUT /mockserver/chaosExperiment). The request body is ignored.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
