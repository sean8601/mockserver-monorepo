meta {
  name: stop the current chaos experiment
  type: http
  seq: 12
}

delete {
  url: {{baseUrl}}/mockserver/chaosExperiment
  body: none
  auth: none
}

docs {
  Stops the current experiment and clears all chaos from the service registry. Idempotent — no-op if no experiment is running.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
