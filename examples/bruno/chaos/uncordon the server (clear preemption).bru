meta {
  name: uncordon the server (clear preemption)
  type: http
  seq: 15
}

delete {
  url: {{baseUrl}}/mockserver/preemption
  body: none
  auth: inherit
}

docs {
  Explicitly clears any active preemption simulation, returning the server to normal operation. Idempotent — returns 200 whether or not a simulation was active.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
