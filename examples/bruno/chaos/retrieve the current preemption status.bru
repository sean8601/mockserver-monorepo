meta {
  name: retrieve the current preemption status
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/mockserver/preemption
  body: none
  auth: inherit
}

docs {
  Returns the current cordon/drain status: state (inactive / draining / drained), the number of in-flight requests, the remaining drain window in milliseconds and the active signalling mode.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
