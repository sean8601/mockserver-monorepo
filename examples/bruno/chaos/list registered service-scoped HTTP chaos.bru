meta {
  name: list registered service-scoped HTTP chaos
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/mockserver/serviceChaos
  body: none
  auth: inherit
}

docs {
  returns all registered service-scoped chaos profiles keyed by host, plus any remaining time-to-live
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
