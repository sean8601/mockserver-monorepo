meta {
  name: list registered TCP chaos
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/mockserver/tcpChaos
  body: none
  auth: inherit
}

docs {
  returns all registered TCP chaos profiles keyed by host, plus any remaining time-to-live
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
