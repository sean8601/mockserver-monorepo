meta {
  name: reset the gRPC descriptor store
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/mockserver/grpc/clear
  body: none
  auth: none
}

docs {
  clears all loaded gRPC proto descriptors and the services derived from them
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
