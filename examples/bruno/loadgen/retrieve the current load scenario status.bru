meta {
  name: retrieve the current load scenario status
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/mockserver/loadScenario
  body: none
  auth: inherit
}

docs {
  Returns the status of the current (or most recent) load scenario: lifecycle state, elapsed time, current virtual users, request counts and latency percentiles. When no scenario has ever run the state is "none".
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
