meta {
  name: retrieve one registered load scenario
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/mockserver/loadScenario/checkout
  body: none
  auth: inherit
}

docs {
  Returns a single registered load scenario (definition + state + live/terminal status). 404 if not registered.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
