meta {
  name: clear the load scenario registry
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/mockserver/loadScenario
  body: none
  auth: inherit
}

docs {
  Removes ALL registered load scenarios, stopping any that are running. Idempotent.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
