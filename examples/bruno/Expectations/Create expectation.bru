meta {
  name: Create expectation (GET /hello -> 200)
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/mockserver/expectation
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "httpRequest": { "method": "GET", "path": "/hello" },
    "httpResponse": { "statusCode": 200, "body": "Hello World" }
  }
}

docs {
  Register an expectation. Returns 201 with the created expectation(s).
}
