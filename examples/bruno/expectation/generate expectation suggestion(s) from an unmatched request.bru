meta {
  name: generate expectation suggestion(s) from an unmatched request
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/mockserver/generateExpectation
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "request": {
      "method": "POST",
      "path": "/api/orders"
    },
    "preview": true,
    "limit": 1
  }
}

docs {
  Generates one or more suggested expectations for an unmatched HttpRequest. When 'preview' is true (the default) the suggestions are only returned; when false they are also added. If an LLM backend is configured it is used, otherwise a simple template-based stub is generated.
  
  the unmatched request to generate expectation(s) for
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
