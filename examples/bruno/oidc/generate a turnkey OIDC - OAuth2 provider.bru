meta {
  name: generate a turnkey OIDC / OAuth2 provider
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/mockserver/oidc
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "issuer": "http://localhost:1080",
    "clientId": "my-app",
    "subject": "test-user",
    "audience": "api://my-api",
    "scopes": [
      "openid",
      "profile",
      "email"
    ],
    "tokenExpirySeconds": 7200
  }
}

docs {
  Generates a set of expectations that emulate an OpenID Connect / OAuth2 provider (discovery document, JWKS, token, authorize, userinfo and related endpoints) and adds them. An empty body uses the default provider configuration.
  
  OIDC provider configuration
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
