meta {
  name: retrieve AsyncAPI mock status
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/mockserver/asyncapi
  body: none
  auth: inherit
}

docs {
  returns the status of the currently loaded AsyncAPI mock. Requires the mockserver-async module on the classpath.
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
