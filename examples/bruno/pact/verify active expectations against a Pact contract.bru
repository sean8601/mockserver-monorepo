meta {
  name: verify active expectations against a Pact contract
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/mockserver/pact/verify
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "consumer": {
      "name": "web-app"
    },
    "provider": {
      "name": "api-service"
    },
    "interactions": [
      {
        "description": "a health check request",
        "request": {
          "method": "GET",
          "path": "/api/health"
        },
        "response": {
          "status": 200,
          "headers": {
            "content-type": "application/json"
          },
          "body": {
            "status": "ok"
          }
        }
      }
    ]
  }
}

docs {
  Verifies the supplied Pact contract (JSON) against the current expectations and returns the verification result. Returns 202 when verification passes and 406 when it fails.
  
  the Pact contract to verify
  
  Full API reference: https://www.mock-server.com/mock_server/mockserver_clients.html
}
