{
  "httpRequest": {
    "method": "POST",
    "path": "/graphql",
    "body": {
      "type": "GRAPHQL",
      "query": "query GetUser($id: ID!) { user(id: $id) { name email } }"
    }
  },
  "httpResponse": {
    "statusCode": 200,
    "headers": {
      "Content-Type": ["application/json"]
    },
    "body": "{\"data\":{\"user\":{\"name\":\"Alice\",\"email\":\"alice@example.com\"}}}"
  }
}
